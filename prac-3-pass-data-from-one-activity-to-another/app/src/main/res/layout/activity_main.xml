<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools" android:id="@+id/main"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" tools:context=".MainActivity">
    <Toolbar android:layout_width="520dp" android:layout_height="50dp"
        android:title="Activity" android:layout_marginRight="-510dp"
        android:background="#CCAAB6"/>

    <EditText
        android:id="@+id/edit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="250dp"
        android:hint="Enter your Name"
        android:minHeight="48dp" />
    <Button android:id="@+id/btn" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Submit"/>
</androidx.appcompat.widget.LinearLayoutCompat>