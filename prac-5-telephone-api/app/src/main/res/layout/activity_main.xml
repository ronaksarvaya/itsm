<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools" android:id="@+id/main"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" tools:context=".MainActivity">
    <androidx.appcompat.widget.Toolbar android:layout_width="match_parent"
        android:layout_height="50dp" android:title="Telephone"
        android:background="#2BCBDC"/>
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:padding="55dp">
        <EditText android:id="@+id/input" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Enter your number"
            android:inputType="phone"/>
        <Button android:id="@+id/btn" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Call"/>
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>